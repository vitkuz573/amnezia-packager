{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended"
  ],
  "labels": ["dependencies"],
  "packageRules": [
    {
      "matchUpdateTypes": ["major"],
      "labels": ["major", "dependencies"]
    },
    {
      "matchUpdateTypes": ["minor", "patch"],
      "labels": ["minor", "dependencies"]
    }
  ]
}
